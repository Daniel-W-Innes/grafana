              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "hidden": false,
                    "query": {
                      "datasource": {
                        "name": "${ds_influxdb}"
                      },
                      "group": "influxdb",
                      "kind": "DataQuery",
                      "spec": {
                        "query": "from(bucket: \"konnected\")\n  |\u003e range(start: v.timeRangeStart, stop:v.timeRangeStop)\n  |\u003e filter(fn: (r) =\u003e\n    r._measurement == \"Frontdoor\" and\n    r._field == \"value\"\n  )"
